# Copy this to .env and fill in your values.
# Bun loads .env from the working directory automatically — no extra setup needed.
# Run from experiments/nrepl-mesh/:  bun src/nrepl-local.ts

# Node ID advertised to the mesh (each node must be unique)
NODE_ID=local

# Redis / Upstash broker URL
# Local Redis:   redis://localhost:6379
# Upstash:       rediss://:your-password@your-host.upstash.io:6380
REDIS_URL=redis://localhost:6379

# nREPL port (editor connects here)
NREPL_PORT=7888

# nREPL bind address (nrepl-server.ts only; nrepl-local.ts always binds 127.0.0.1)
# NREPL_HOST=0.0.0.0
